{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": [
      "ES2020"
    ],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@__tests__/*": [
        "__tests__/*"
      ],
      "@src/*": [
        "src/*",
      ],
      "@commands": [
        "src/commands/index.ts",
      ],
      "@commands/*": [
        "src/commands/*/cmd.ts",
      ],
      "@definition": [
        "src/commands/definition.ts",
      ],
      "@consts": [
        "src/commands/consts.ts",
      ],
      "@config": [
        "src/config/index.ts",
      ],
      "@lib/*": [
        "src/lib/*",
      ]
    }
  },
  "include": [
    "src/**/*",
    "__tests__/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}